# Copy this file to .env and fill in your values.
# REQUIRED for production SEO (affects canonical URLs, sitemaps, OG tags):
SITE_URL=https://www.yourdomain.com
SITE_NAME=Healix

# REQUIRED for real product photos (free — get key at pexels.com/api in 30 sec):
PEXELS_API_KEY=your_free_key_here

# Copy this to .env and adjust as needed.
# The app loads this automatically via python-dotenv.

# Path to the CSV (default: ../medical_supplies.csv)
# CSV_PATH=/absolute/path/to/medical_supplies.csv

# Gunicorn workers (default: min(4, cpu_count*2+1))
# WEB_CONCURRENCY=4

# Threads per worker (default: 4)
# THREADS=4

# Server bind address (default: 0.0.0.0:5000)
# BIND=0.0.0.0:5000

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
